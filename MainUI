            MainFrame.Visible = true
            Tween(MainFrame, { Position = UDim2.new(0.5, -360, 0.5, -240), BackgroundTransparency = 0 }, 0.3)
        else
            Tween(MainFrame, { Position = UDim2.new(0.5, -360, 1.5, 0), BackgroundTransparency = 1 }, 0.25)
            task.wait(0.3)
            MainFrame.Visible = false
        end
    end
