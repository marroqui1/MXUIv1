    -- Overlay frame: parent for dropdowns so they always draw on top
    local Overlay = Make("Frame", {
        Name                   = "Overlay",
        Size                   = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        ZIndex                 = 8000,
    }, Gui)

    -- ── Main frame ───────────────────────────────────────────────────────────
