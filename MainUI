    -- ‚ĒÄ‚ĒÄ Window:SetDetectionStatus(state) ‚ĒÄ‚ĒÄ
    --[[
        Sets the overall window status dot (in titlebar).
        state: "Working" | "Fixing" | "Detected"
    --]]
    function Window:SetDetectionStatus(state)
        -- Find or create status dot in titlebar
        local col = state == "Working" and C.Working
                 or state == "Fixing"  and C.Fixing
                 or C.Detected
        local dot = Titlebar:FindFirstChild("StatusDot")
        if not dot then
            dot = Make("Frame", {
                Name            = "StatusDot",
                Size            = UDim2.new(0, 8, 0, 8),
                Position        = UDim2.new(0, W/2 - 40, 0.5, -4),
                BackgroundColor3 = col,
                BorderSizePixel = 0,
                ZIndex          = 7,
            }, Titlebar)
            MakeCorner(4, dot)
        end
        Tween(dot, {BackgroundColor3 = col}, 0.2)
    end

    -- ‚ĒÄ‚ĒÄ Window:Notify(config) ‚ĒÄ‚ĒÄ
    --[[
        Shows a small notification popup.
        Window:Notify({
            Title   = "Notice",
            Content = "Aimbot enabled",
            Duration = 3,
        })
    --]]
    function Window:Notify(config)
        config = config or {}
        local notif = Make("Frame", {
            Name            = "Notif",
            Size            = UDim2.new(0, 220, 0, 54),
            Position        = UDim2.new(1, 240, 1, -64),
            BackgroundColor3 = C.BgCard,
            BorderSizePixel = 0,
            ZIndex          = 50,
        }, Gui)
        MakeCorner(8, notif)
        MakeStroke(1, theme.Accent, notif)
        MakePadding(8, 8, 12, 12, notif)

        Make("Frame", {
            Size            = UDim2.new(0, 3, 1, 0),
            BackgroundColor3 = theme.Accent,
            BorderSizePixel = 0,
            ZIndex          = 51,
        }, notif)

        Make("TextLabel", {
            Text            = config.Title or "Nova",
            Size            = UDim2.new(1, -8, 0, 18),
            Position        = UDim2.new(0, 8, 0, 0),
            BackgroundTransparency = 1,
            TextColor3      = theme.AccentLight,
            Font            = Enum.Font.GothamBold,
            TextSize        = 13,
            TextXAlignment  = Enum.TextXAlignment.Left,
            ZIndex          = 52,
        }, notif)

        Make("TextLabel", {
            Text            = config.Content or "",
            Size            = UDim2.new(1, -8, 0, 18),
            Position        = UDim2.new(0, 8, 0, 20),
            BackgroundTransparency = 1,
            TextColor3      = C.TextSec,
            Font            = Enum.Font.Gotham,
            TextSize        = 11,
            TextXAlignment  = Enum.TextXAlignment.Left,
            ZIndex          = 52,
        }, notif)

        -- Slide in
        Tween(notif, {Position = UDim2.new(1, -230, 1, -64)}, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

        task.delay(config.Duration or 3, function()
            Tween(notif, {Position = UDim2.new(1, 240, 1, -64)}, 0.25)
            task.wait(0.3)
            notif:Destroy()
        end)
    end

    return Window
end

