        --[[
            Tab:Keybind("Label", "E", function(key)
                -- key = KeyCode name string e.g. "E"
            end)
            
            Returns :Set(keyName) and :Get().
        --]]
        function Tab:Keybind(label, default, callback)
            local row     = BaseRow(40)
            local current = default or "None"
            local listening = false
            MakePadding(0, 0, 12, 12, row)

            Make("TextLabel", {
                Text            = label,
                Size            = UDim2.new(0.6, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3      = C.TextPrim,
                Font            = Enum.Font.GothamSemibold,
                TextSize        = 13,
                TextXAlignment  = Enum.TextXAlignment.Left,
                ZIndex          = 6,
            }, row)

            local KeyBtn = Make("TextButton", {
                Text            = "[" .. current .. "]",
                Size            = UDim2.new(0, 80, 0, 26),
                Position        = UDim2.new(1, -80, 0.5, -13),
                BackgroundColor3 = C.BgInput,
                TextColor3      = C.TextPrim,
                Font            = Enum.Font.Code,
                TextSize        = 12,
                BorderSizePixel = 0,
                AutoButtonColor = false,
                ZIndex          = 6,
            }, row)
            MakeCorner(5, KeyBtn)
            MakeStroke(1, C.Border, KeyBtn)

            KeyBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening = true
                KeyBtn.Text = "..."
                Tween(KeyBtn, {BackgroundColor3 = Color3.fromRGB(
                    math.floor(theme.Accent.R*255*0.15+C.BgInput.R*255*0.85),
                    math.floor(theme.Accent.G*255*0.15+C.BgInput.G*255*0.85),
                    math.floor(theme.Accent.B*255*0.15+C.BgInput.B*255*0.85)
                )}, 0.1)

                local conn
                conn = UserInputService.InputBegan:Connect(function(input, gpe)
                    if gpe then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        current = input.KeyCode.Name
                        KeyBtn.Text = "[" .. current .. "]"
                        Tween(KeyBtn, {BackgroundColor3 = C.BgInput}, 0.1)
                        listening = false
                        conn:Disconnect()
                        if callback then callback(current) end
                    end
                end)
            end)

            return {
                Set = function(k) current = k; KeyBtn.Text = "[" .. k .. "]" end,
                Get = function() return current end,
            }
        end

