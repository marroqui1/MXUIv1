        --[[
            Tab:ColorPicker("Label", Color3.fromRGB(255,0,0), function(color)
                -- color = Color3 value
            end)
        --]]
        function Tab:ColorPicker(label, default, callback)
            local row = BaseRow(40)
            local current = default or Color3.fromRGB(255, 100, 100)
            MakePadding(0, 0, 12, 12, row)

            Make("TextLabel", {
                Text            = label,
                Size            = UDim2.new(0.6, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3      = C.TextPrim,
                Font            = Enum.Font.GothamSemibold,
                TextSize        = 13,
                TextXAlignment  = Enum.TextXAlignment.Left,
                ZIndex          = 6,
            }, row)

            local presets = {
                Color3.fromRGB(108,99,255),
                Color3.fromRGB(0,212,170),
                Color3.fromRGB(255,71,87),
                Color3.fromRGB(255,165,2),
                Color3.fromRGB(255,255,255),
                Color3.fromRGB(50,170,255),
            }

            local SwatchRow = Make("Frame", {
                Size            = UDim2.new(0, #presets * 22, 1, 0),
                Position        = UDim2.new(1, -(#presets * 22), 0, 0),
                BackgroundTransparency = 1,
                ZIndex          = 6,
            }, row)

            Make("UIListLayout", {
                FillDirection = Enum.FillDirection.Horizontal,
                Padding       = UDim.new(0, 3),
                VerticalAlignment = Enum.VerticalAlignment.Center,
            }, SwatchRow)

            for _, col in ipairs(presets) do
                local sw = Make("TextButton", {
                    Text            = "",
                    Size            = UDim2.new(0, 18, 0, 18),
                    BackgroundColor3 = col,
                    BorderSizePixel = 0,
                    AutoButtonColor = false,
                    ZIndex          = 7,
                }, SwatchRow)
                MakeCorner(4, sw)
                local stroke = MakeStroke(col == current and 2 or 1,
                    col == current and C.White or Color3.fromRGB(255,255,255), sw)
                stroke.Transparency = col == current and 0 or 0.7

                sw.MouseButton1Click:Connect(function()
                    current = col
                    -- Reset all strokes
                    for _, s in ipairs(SwatchRow:GetChildren()) do
                        if s:IsA("TextButton") then
                            local st = s:FindFirstChildOfClass("UIStroke")
                            if st then
                                st.Thickness    = s.BackgroundColor3 == col and 2 or 1
                                st.Transparency = s.BackgroundColor3 == col and 0 or 0.7
                            end
                        end
                    end
                    if callback then callback(col) end
                end)
            end

            return {
                Get = function() return current end,
                Set = function(c) current = c; if callback then callback(c) end end,
            }
        end

        -- ‚ĒÄ‚ĒÄ DETECTION STATUS ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ‚ĒÄ
        --[[
            Tab:DetectionStatus("Module Name", "Working")
            -- state: "Working" | "Fixing" | "Detected"
            
            Returns :SetState("Working"|"Fixing"|"Detected")
        --]]
        function Tab:DetectionStatus(label, initialState)
            local row = BaseRow(40)
            local states = {"Working", "Fixing", "Detected"}
            local stateColors = {
                Working  = C.Working,
                Fixing   = C.Fixing,
                Detected = C.Detected,
            }
            local current = initialState or "Working"
            MakePadding(0, 0, 12, 12, row)

            Make("TextLabel", {
                Text            = label,
                Size            = UDim2.new(0.5, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3      = C.TextPrim,
                Font            = Enum.Font.GothamSemibold,
                TextSize        = 13,
                TextXAlignment  = Enum.TextXAlignment.Left,
                ZIndex          = 6,
            }, row)

            -- Three state buttons ‚ÄĒ only one lit at a time
            local BtnRow = Make("Frame", {
                Size            = UDim2.new(0.47, 0, 0, 26),
                Position        = UDim2.new(0.53, 0, 0.5, -13),
                BackgroundTransparency = 1,
                ZIndex          = 6,
            }, row)

            Make("UIListLayout", {
                FillDirection = Enum.FillDirection.Horizontal,
                Padding       = UDim.new(0, 4),
                VerticalAlignment = Enum.VerticalAlignment.Center,
            }, BtnRow)

            local stateBtns = {}

            local function UpdateButtons(active)
                current = active
                for _, info in ipairs(stateBtns) do
                    local isActive = info.name == active
                    local col = stateColors[info.name]
                    Tween(info.btn, {
                        BackgroundColor3 = isActive
                            and Color3.fromRGB(col.R*255*0.15+C.BgInput.R*255*0.85,
                                               col.G*255*0.15+C.BgInput.G*255*0.85,
                                               col.B*255*0.15+C.BgInput.B*255*0.85)
                            or C.BgInput,
                        TextColor3 = isActive and col or C.TextMuted,
                    }, 0.15)
                    local stroke = info.btn:FindFirstChildOfClass("UIStroke")
                    if stroke then
                        Tween(stroke, {Color = isActive and col or C.Border, Transparency = isActive and 0 or 0.5}, 0.15)
                    end
                    -- Dot
                    local dot = info.btn:FindFirstChild("Dot")
                    if dot then
                        Tween(dot, {BackgroundColor3 = isActive and col or C.TextMuted}, 0.15)
                        dot.Visible = isActive
                    end
                end
            end

            for _, name in ipairs(states) do
                local col      = stateColors[name]
                local isActive = name == current

                local btn = Make("TextButton", {
                    Name            = name,
                    Text            = "  " .. name,
                    Size            = UDim2.new(0, #name * 7 + 14, 1, 0),
                    BackgroundColor3 = isActive
                        and Color3.fromRGB(col.R*255*0.15+C.BgInput.R*255*0.85,
                                           col.G*255*0.15+C.BgInput.G*255*0.85,
                                           col.B*255*0.15+C.BgInput.B*255*0.85)
                        or C.BgInput,
                    TextColor3      = isActive and col or C.TextMuted,
                    Font            = Enum.Font.Code,
                    TextSize        = 10,
                    BorderSizePixel = 0,
                    AutoButtonColor = false,
                    TextXAlignment  = Enum.TextXAlignment.Right,
                    ZIndex          = 7,
                }, BtnRow)
                MakeCorner(4, btn)
                local stroke = MakeStroke(1, isActive and col or C.Border, btn)
                stroke.Transparency = isActive and 0 or 0.5

                -- Dot indicator
                local dot = Make("Frame", {
                    Name            = "Dot",
                    Size            = UDim2.new(0, 6, 0, 6),
                    Position        = UDim2.new(0, 5, 0.5, -3),
                    BackgroundColor3 = isActive and col or C.TextMuted,
                    BorderSizePixel = 0,
                    Visible         = isActive,
                    ZIndex          = 8,
                }, btn)
                MakeCorner(3, dot)

                table.insert(stateBtns, {btn = btn, name = name})

                btn.MouseButton1Click:Connect(function()
                    UpdateButtons(name)
                end)
            end

            return {
                SetState = UpdateButtons,
                GetState = function() return current end,
            }
        end

