            CardHover(card)
            return {
                Get = function() return box.Text end,
                Set = function(v) box.Text = v end,
            }
        end

        -- ── BUTTON ───────────────────────────────────────────────────────────
        function t:Button(label, callback)
            local card = Card(42)
            AddPadding(0, 0, 12, 12, card)

            local btn = Make("TextButton", {
                Text             = label,
                Size             = UDim2.new(1, 0, 0, 30),
                Position         = UDim2.new(0, 0, 0.5, -15),
                BackgroundColor3 = theme.dark,
                TextColor3       = C.white,
                Font             = Enum.Font.GothamBold,
                TextSize         = 13,
                BorderSizePixel  = 0,
                AutoButtonColor  = false,
                ZIndex           = 24,
            }, card)
            AddCorner(7, btn)
            Make("UIGradient", {
                Color    = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, theme.dark),
                    ColorSequenceKeypoint.new(1, theme.main),
                }),
                Rotation = 90,
            }, btn)

            btn.MouseEnter:Connect(function()  Tween(btn, { BackgroundColor3 = theme.main }, 0.12) end)
            btn.MouseLeave:Connect(function()  Tween(btn, { BackgroundColor3 = theme.dark }, 0.12) end)
            btn.MouseButton1Click:Connect(function()
                Tween(btn, { BackgroundColor3 = theme.light }, 0.07)
                task.wait(0.09)
                Tween(btn, { BackgroundColor3 = theme.main }, 0.1)
                if callback then callback() end
            end)
        end

        -- ── COLOR PICKER ─────────────────────────────────────────────────────
        function t:ColorPicker(label, default, callback)
            local card    = Card(42)
            local current = default or Color3.fromRGB(108, 99, 255)
            local presets = {
                Color3.fromRGB(108, 99, 255), Color3.fromRGB(0, 212, 170),
                Color3.fromRGB(255, 71, 87),  Color3.fromRGB(255, 165, 2),
                Color3.fromRGB(50, 170, 255), Color3.fromRGB(255, 255, 255),
            }
            AddPadding(0, 0, 14, 14, card)

            Make("TextLabel", {
                Text                   = label,
                Size                   = UDim2.new(0.48, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = C.txt1,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 24,
            }, card)

            local swRow = Make("Frame", {
                Size             = UDim2.new(0, #presets * 23, 1, 0),
                Position         = UDim2.new(1, -#presets * 23, 0, 0),
                BackgroundTransparency = 1,
                ZIndex           = 24,
            }, card)
            AddHList(4, swRow)

            local swatches = {}
            for idx, col in ipairs(presets) do
                local sw = Make("TextButton", {
                    Text             = "",
                    Size             = UDim2.new(0, 18, 0, 18),
                    BackgroundColor3 = col,
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    LayoutOrder      = idx,
                    ZIndex           = 25,
                }, swRow)
                AddCorner(5, sw)
                local isActive = (col == current)
                local swStr = AddStroke(isActive and 2 or 1, isActive and C.white or C.bdr, sw)
                swStr.Transparency = isActive and 0 or 0.4

                sw.MouseButton1Click:Connect(function()
                    current = col
                    for _, s in ipairs(swatches) do
                        local active = (s.col == col)
                        Tween(s.str, { Color = active and C.white or C.bdr, Thickness = active and 2 or 1 }, 0.12)
                        s.str.Transparency = active and 0 or 0.4
                    end
                    if callback then callback(col) end
                end)

                table.insert(swatches, { sw = sw, str = swStr, col = col })
            end

            CardHover(card)
            return {
                Get = function() return current end,
                Set = function(c) current = c; if callback then callback(c) end end,
            }
        end

        -- ── DETECTION STATUS ─────────────────────────────────────────────────
        -- Three state buttons: only ONE is lit at a time.
        -- States: "Working" (green) | "Fixing" (yellow) | "Detected" (red)
        function t:DetectionStatus(label, initial)
            local card    = Card(42)
            local current = initial or "Working"
            local STATE_COLORS = {
                Working  = C.green,
                Fixing   = C.yellow,
                Detected = C.red,
            }
            local STATE_ORDER = { "Working", "Fixing", "Detected" }
            AddPadding(0, 0, 14, 14, card)

            Make("TextLabel", {
                Text                   = label,
                Size                   = UDim2.new(0.4, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = C.txt1,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 24,
            }, card)

            local btnRow = Make("Frame", {
                Size             = UDim2.new(0.58, 0, 0, 28),
                Position         = UDim2.new(0.42, 0, 0.5, -14),
                BackgroundTransparency = 1,
                ZIndex           = 24,
            }, card)
            AddHList(4, btnRow)

            local stateBtns = {}

            local function UpdateStates(active)
                current = active
                for _, info in ipairs(stateBtns) do
                    local isActive = (info.name == active)
                    local col      = STATE_COLORS[info.name]
                    Tween(info.btn, {
                        BackgroundColor3 = isActive and Tint(col, C.bg4, 0.82) or C.bg4,
                        TextColor3       = isActive and col or C.txt3,
                    }, 0.15)
                    Tween(info.stroke, {
                        Color        = isActive and col or C.bdr,
                        Transparency = isActive and 0 or 0.55,
                    }, 0.15)
                    info.dot.Visible          = isActive
                    info.dot.BackgroundColor3 = col
                end
            end

            for _, name in ipairs(STATE_ORDER) do
                local col      = STATE_COLORS[name]
                local isActive = (name == current)
                local bW       = #name * 7 + 20

                local btn = Make("TextButton", {
                    Name             = name,
                    Text             = "   " .. name,
                    Size             = UDim2.new(0, bW, 1, 0),
                    BackgroundColor3 = isActive and Tint(col, C.bg4, 0.82) or C.bg4,
                    TextColor3       = isActive and col or C.txt3,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 10,
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    TextXAlignment   = Enum.TextXAlignment.Right,
                    ZIndex           = 25,
                }, btnRow)
                AddCorner(6, btn)
                local st = AddStroke(1, isActive and col or C.bdr, btn)
                st.Transparency = isActive and 0 or 0.55

                local dot = Make("Frame", {
                    Size             = UDim2.new(0, 6, 0, 6),
                    Position         = UDim2.new(0, 5, 0.5, -3),
                    BackgroundColor3 = col,
                    BorderSizePixel  = 0,
                    Visible          = isActive,
                    ZIndex           = 26,
                }, btn)
                AddCorner(3, dot)

                table.insert(stateBtns, { btn = btn, stroke = st, dot = dot, name = name })
                btn.MouseButton1Click:Connect(function() UpdateStates(name) end)
            end

            CardHover(card)
            return {
                SetState = UpdateStates,
                GetState = function() return current end,
            }
        end

        return t
    end -- Win:Tab

    -- ── Win:Notify(cfg) ───────────────────────────────────────────────────────
    function Win:Notify(cfg)
        cfg        = cfg or {}
        local TH   = self._theme
        local nW   = 232
        local nH   = 60

        local notif = Make("Frame", {
            Size             = UDim2.new(0, nW, 0, nH),
            Position         = UDim2.new(1, nW + 10, 1, -(nH + 10)),
            BackgroundColor3 = C.bg3,
            BorderSizePixel  = 0,
            ZIndex           = 9100,
        }, Gui)
        AddCorner(10, notif)
        AddStroke(1, TH.main, notif)

        -- accent left bar
        Make("Frame", {
            Size             = UDim2.new(0, 3, 0.65, 0),
            Position         = UDim2.new(0, 0, 0.175, 0),
            BackgroundColor3 = TH.main,
            BorderSizePixel  = 0,
            ZIndex           = 9101,
        }, notif)

        Make("TextLabel", {
            Text                   = cfg.Title or "Nova",
            Size                   = UDim2.new(1, -12, 0, 22),
            Position               = UDim2.new(0, 12, 0, 6),
            BackgroundTransparency = 1,
            TextColor3             = TH.light,
            Font                   = Enum.Font.GothamBold,
            TextSize               = 13,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 9102,
        }, notif)

        Make("TextLabel", {
            Text                   = cfg.Content or "",
            Size                   = UDim2.new(1, -12, 0, 20),
            Position               = UDim2.new(0, 12, 0, 30),
            BackgroundTransparency = 1,
            TextColor3             = C.txt2,
            Font                   = Enum.Font.Gotham,
            TextSize               = 11,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 9102,
        }, notif)

        Tween(notif, { Position = UDim2.new(1, -(nW + 10), 1, -(nH + 10)) },
              0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

        task.delay(cfg.Duration or 3, function()
            Tween(notif, { Position = UDim2.new(1, nW + 10, 1, -(nH + 10)) }, 0.25)
            task.wait(0.3)
            notif:Destroy()
        end)
    end

    -- ── Win:SetStatus(state) ──────────────────────────────────────────────────
    function Win:SetStatus(state)
        local col = state == "Working" and C.green
                 or state == "Fixing"  and C.yellow
                 or C.red

        local dot = Titlebar:FindFirstChild("StatusDot")
        if not dot then
            dot = Make("Frame", {
                Name             = "StatusDot",
                Size             = UDim2.new(0, 8, 0, 8),
                Position         = UDim2.new(0.5, -4, 0.5, -4),
                BackgroundColor3 = col,
                BorderSizePixel  = 0,
                ZIndex           = 32,
            }, Titlebar)
            AddCorner(4, dot)
        end
        Tween(dot, { BackgroundColor3 = col }, 0.2)
    end

    return Win
end -- Nova.Window

return Nova
