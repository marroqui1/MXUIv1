            Size             = UDim2.new(0, 36, 0, 18),
            Position         = UDim2.new(0, 18 + (#(cfg.Title or "Nova") * 9), 0.5, -9),
            BackgroundColor3 = C.bg4,
            BorderSizePixel  = 0,
            ZIndex           = 32,
        }, Titlebar)
        AddCorner(5, badgeFr)
        AddStroke(1, Tint(theme.main, C.bdr, 0.4), badgeFr)
