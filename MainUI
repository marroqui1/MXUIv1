-- Tween shorthand
local function Tween(obj, goal, t, style, dir)
    TweenService:Create(obj, TweenInfo.new(
        t     or 0.18,
        style or Enum.EasingStyle.Quad,
        dir   or Enum.EasingDirection.Out
    ), goal):Play()
end

-- Create instance with property table
local function Make(className, props, parent)
    local obj = Instance.new(className)
    for k, v in pairs(props) do
        obj[k] = v
    end
    if parent then
        obj.Parent = parent
    end
    return obj
end

-- UICorner helper
local function AddCorner(radius, parent)
    Make("UICorner", { CornerRadius = UDim.new(0, radius) }, parent)
end

-- UIStroke helper
local function AddStroke(thickness, color, parent)
    return Make("UIStroke", {
        Thickness       = thickness or 1,
        Color           = color or C.bdr,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    }, parent)
end

-- UIPadding helper
local function AddPadding(top, bottom, left, right, parent)
    Make("UIPadding", {
        PaddingTop    = UDim.new(0, top    or 0),
        PaddingBottom = UDim.new(0, bottom or 0),
        PaddingLeft   = UDim.new(0, left   or 0),
        PaddingRight  = UDim.new(0, right  or 0),
    }, parent)
end

-- UIListLayout horizontal
local function AddHList(gap, parent)
    Make("UIListLayout", {
        FillDirection       = Enum.FillDirection.Horizontal,
        VerticalAlignment   = Enum.VerticalAlignment.Center,
        SortOrder           = Enum.SortOrder.LayoutOrder,
        Padding             = UDim.new(0, gap or 0),
    }, parent)
end

-- UIListLayout vertical
local function AddVList(gap, parent)
    Make("UIListLayout", {
        FillDirection       = Enum.FillDirection.Vertical,
        HorizontalAlignment = Enum.HorizontalAlignment.Left,
        SortOrder           = Enum.SortOrder.LayoutOrder,
        Padding             = UDim.new(0, gap or 0),
    }, parent)
end

-- White ImageLabel icon
local function AddIcon(iconName, size, parent)
    local img = Make("ImageLabel", {
        Image               = ICONS[iconName] or ICONS.star,
        Size                = UDim2.new(0, size, 0, size),
        BackgroundTransparency = 1,
        ImageColor3         = C.white,
        ScaleType           = Enum.ScaleType.Fit,
        ZIndex              = parent and parent.ZIndex or 1,
    }, parent)
    return img
end

-- Linear interpolate two Color3
local function LerpColor(a, b, t)
    return Color3.new(
        a.R + (b.R - a.R) * t,
        a.G + (b.G - a.G) * t,
        a.B + (b.B - a.B) * t
    )
end

-- Tint accent toward background
local function Tint(accent, bg, amount)
    return LerpColor(accent, bg, amount)
end

