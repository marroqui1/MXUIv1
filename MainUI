        Position               = UDim2.new(0, 70, 0, 0),
        BackgroundTransparency = 1,
        TextColor3             = C.txt3,
        Font                   = Enum.Font.Code,
        TextSize               = 10,
        TextXAlignment         = Enum.TextXAlignment.Right,
        ZIndex                 = 31,
    }, StatusBar)

    RunService.RenderStepped:Connect(function()
        local col = currentFPS >= 60 and C.green or currentFPS >= 30 and C.yellow or C.red
        FpsLabel.Text       = "FPS " .. currentFPS
        FpsLabel.TextColor3 = col
    end)

    -- ─────────────────────────────────────────────────────────────────────────
    -- WINDOW OBJECT
    -- ─────────────────────────────────────────────────────────────────────────
    local Win = {
        _tabs    = {},
        _active  = nil,
        _theme   = theme,
        _gui     = Gui,
        _overlay = Overlay,
    }

    -- Internal: deactivate all tabs then activate one
    local function ActivateTab(target)
        for _, t in ipairs(Win._tabs) do
            -- sidebar button
            Tween(t._sbBtn, { BackgroundColor3 = C.bg3 }, 0.15)
            t._sbIcon.ImageColor3  = C.txt2
            t._sbLabel.TextColor3  = C.txt2
            t._sbBar.BackgroundTransparency = 1
            -- tab bar pill
            Tween(t._tbBtn, { BackgroundColor3 = C.bg2 }, 0.15)
            t._tbIcon.ImageColor3  = C.txt2
            t._tbLabel.TextColor3  = C.txt2
            t._tbUnderline.BackgroundTransparency = 1
            -- content
            t._content.Visible = false
        end

        Tween(target._sbBtn, { BackgroundColor3 = Tint(theme.main, C.bg3, 0.86) }, 0.15)
        target._sbIcon.ImageColor3  = C.white
        target._sbLabel.TextColor3  = C.txt1
        target._sbBar.BackgroundTransparency = 0

        Tween(target._tbBtn, { BackgroundColor3 = Tint(theme.main, C.bg2, 0.82) }, 0.15)
        target._tbIcon.ImageColor3  = theme.light
        target._tbLabel.TextColor3  = theme.light
        target._tbUnderline.BackgroundTransparency = 0

        target._content.Visible = true
        Win._active = target
        ContentScroll.CanvasPosition = Vector2.new(0, 0)
    end

    -- ─────────────────────────────────────────────────────────────────────────
    -- Win:Tab(name, iconName)
    -- ─────────────────────────────────────────────────────────────────────────
    function Win:Tab(name, iconName)
        local t       = {}
        local order   = #self._tabs + 1
        local elemOrd = 0

        -- ── Sidebar button ────────────────────────────────────────────────────
        local sbBtn = Make("TextButton", {
            Text             = "",
            Name             = "SB_" .. name,
            Size             = UDim2.new(1, 0, 0, 40),
            BackgroundColor3 = C.bg3,
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            LayoutOrder      = order,
            ZIndex           = 21,
        }, Sidebar)
        AddCorner(8, sbBtn)
        AddStroke(1, C.bdr, sbBtn)

        -- Active left bar accent
        local sbBar = Make("Frame", {
            Size             = UDim2.new(0, 3, 0.55, 0),
            Position         = UDim2.new(0, 0, 0.225, 0),
            BackgroundColor3 = theme.main,
            BorderSizePixel  = 0,
            BackgroundTransparency = 1,
            ZIndex           = 22,
        }, sbBtn)
        AddCorner(2, sbBar)

        -- Icon + label inside sidebar button
        local sbInner = Make("Frame", {
            Size             = UDim2.new(1, -10, 1, 0),
            Position         = UDim2.new(0, 10, 0, 0),
            BackgroundTransparency = 1,
            ZIndex           = 22,
        }, sbBtn)
        AddHList(9, sbInner)

        local sbIcon = AddIcon(iconName or "star", 15, sbInner)
        sbIcon.ImageColor3 = C.txt2
        sbIcon.LayoutOrder = 1

        local sbLabel = Make("TextLabel", {
            Text                   = name,
            Size                   = UDim2.new(1, -28, 1, 0),
            BackgroundTransparency = 1,
            TextColor3             = C.txt2,
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 13,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 23,
            LayoutOrder            = 2,
        }, sbInner)

        sbBtn.MouseEnter:Connect(function()
            if Win._active ~= t then Tween(sbBtn, { BackgroundColor3 = C.bg4 }, 0.1) end
        end)
        sbBtn.MouseLeave:Connect(function()
            if Win._active ~= t then Tween(sbBtn, { BackgroundColor3 = C.bg3 }, 0.1) end
        end)
        sbBtn.MouseButton1Click:Connect(function() ActivateTab(t) end)

        -- ── Tab bar pill ──────────────────────────────────────────────────────
        local tbW   = #name * 7 + 28
        local tbBtn = Make("TextButton", {
            Text             = "",
            Name             = "TB_" .. name,
            Size             = UDim2.new(0, tbW, 1, -6),
            BackgroundColor3 = C.bg2,
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            LayoutOrder      = order,
            ZIndex           = 22,
        }, TabBar)
        AddCorner(6, tbBtn)

        local tbInner = Make("Frame", {
            Size             = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex           = 23,
        }, tbBtn)
        AddHList(5, tbInner)
        AddPadding(0, 0, 7, 7, tbInner)

        local tbIcon = AddIcon(iconName or "star", 12, tbInner)
        tbIcon.ImageColor3 = C.txt2
        tbIcon.LayoutOrder = 1

        local tbLabel = Make("TextLabel", {
            Text                   = name,
            Size                   = UDim2.new(0, #name * 7, 1, 0),
            BackgroundTransparency = 1,
            TextColor3             = C.txt2,
            Font                   = Enum.Font.GothamSemibold,
            TextSize               = 12,
            TextXAlignment         = Enum.TextXAlignment.Left,
            ZIndex                 = 24,
            LayoutOrder            = 2,
        }, tbInner)

        local tbUnderline = Make("Frame", {
            Size             = UDim2.new(1, -12, 0, 2),
            Position         = UDim2.new(0, 6, 1, -2),
            BackgroundColor3 = theme.main,
            BorderSizePixel  = 0,
            BackgroundTransparency = 1,
            ZIndex           = 24,
        }, tbBtn)
        AddCorner(1, tbUnderline)

        tbBtn.MouseButton1Click:Connect(function() ActivateTab(t) end)

        -- ── Content frame ─────────────────────────────────────────────────────
        local content = Make("Frame", {
            Name             = "Content_" .. name,
            Size             = UDim2.new(1, 0, 0, 0),
            AutomaticSize    = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            BorderSizePixel  = 0,
            Visible          = false,
            ZIndex           = 22,
        }, ContentScroll)
        AddVList(6, content)
        AddPadding(10, 10, 12, 12, content)

        t._sbBtn      = sbBtn
        t._sbIcon     = sbIcon
        t._sbLabel    = sbLabel
        t._sbBar      = sbBar
        t._tbBtn      = tbBtn
        t._tbIcon     = tbIcon
        t._tbLabel    = tbLabel
        t._tbUnderline = tbUnderline
        t._content    = content
        t._theme      = theme

        table.insert(self._tabs, t)
        if #self._tabs == 1 then
            task.defer(function() ActivateTab(t) end)
        end

        -- ── Element helpers ───────────────────────────────────────────────────
        local function NextOrder()
            elemOrd = elemOrd + 1
            return elemOrd
        end

        -- Base card
        local function Card(height)
            local f = Make("Frame", {
                Size             = UDim2.new(1, 0, 0, height or 42),
