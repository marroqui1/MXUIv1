        local dot = Make("TextButton", {
            Text             = "",
            Size             = UDim2.new(0, 13, 0, 13),
            Position         = UDim2.new(1, rightOffset, 0.5, -6),
            BackgroundColor3 = color,
            BorderSizePixel  = 0,
            AutoButtonColor  = false,
            ZIndex           = 32,
        }, Titlebar)
        AddCorner(7, dot)
        dot.MouseEnter:Connect(function() Tween(dot, { BackgroundTransparency = 0.35 }, 0.1) end)
        dot.MouseLeave:Connect(function() Tween(dot, { BackgroundTransparency = 0 }, 0.1) end)
        return dot
    end

    local BtnClose = ControlDot(C.red,    -18)
    local BtnMin   = ControlDot(C.yellow, -38)

    local minimized = false

    BtnClose.MouseButton1Click:Connect(function()
        Tween(Main, { Size = UDim2.new(0, winW, 0, 0) }, 0.22, Enum.EasingStyle.Back, Enum.EasingDirection.In)
        task.wait(0.26)
        Gui:Destroy()
    end)

    BtnMin.MouseButton1Click:Connect(function()
        minimized = not minimized
        local targetH = minimized and TITLE_H or winH
        Tween(Main, { Size = UDim2.new(0, winW, 0, targetH) }, 0.28, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    end)

    MakeDraggable(Main, Titlebar)

    UserInputService.InputBegan:Connect(function(input, gameProcessed)
