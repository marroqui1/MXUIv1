local function FilterScripts(query)
    filteredScripts = {}
    query = query:lower()
    for _, s in ipairs(Scripts) do
        if query == "" or s.name:lower():find(query) or s.game:lower():find(query) then
            table.insert(filteredScripts, s)
        end
    end
end

