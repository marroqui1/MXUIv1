        Name             = "Titlebar",
        Size             = UDim2.new(1, 0, 0, TITLE_H),
        BackgroundColor3 = C.bg2,
        BorderSizePixel  = 0,
        ZIndex           = 30,
    }, Main)
    AddCorner(12, Titlebar)
    -- fill bottom corners of titlebar so it connects cleanly
    Make("Frame", {
        Size             = UDim2.new(1, 0, 0, 12),
        Position         = UDim2.new(0, 0, 1, -12),
        BackgroundColor3 = C.bg2,
        BorderSizePixel  = 0,
        ZIndex           = 30,
    }, Titlebar)
    AddStroke(1, C.bdr, Titlebar)

    -- gradient left→right accent wash
    Make("UIGradient", {
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0,   theme.main),
            ColorSequenceKeypoint.new(0.5, C.bg2),
            ColorSequenceKeypoint.new(1,   C.bg2),
        }),
        Transparency = NumberSequence.new({
            NumberSequenceKeypoint.new(0, 0.72),
            NumberSequenceKeypoint.new(1, 1),
        }),
        Rotation = 0,
    }, Titlebar)

    -- bottom border line on titlebar
    Make("Frame", {
        Size             = UDim2.new(1, 0, 0, 1),
        Position         = UDim2.new(0, 0, 1, -1),
        BackgroundColor3 = theme.main,
        BackgroundTransparency = 0.5,
        BorderSizePixel  = 0,
        ZIndex           = 31,
    }, Titlebar)

    -- Title text
    Make("TextLabel", {
        Text                   = cfg.Title or "Nova",
        Size                   = UDim2.new(0, 220, 1, 0),
        Position               = UDim2.new(0, 14, 0, 0),
        BackgroundTransparency = 1,
        TextColor3             = theme.light,
        Font                   = Enum.Font.GothamBold,
