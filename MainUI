        -- ── TOGGLE ───────────────────────────────────────────────────────────
        function t:Toggle(label, default, callback)
            local card  = Card(42)
            local state = (default == true)
            AddPadding(0, 0, 14, 14, card)

            Make("TextLabel", {
                Text                   = label,
                Size                   = UDim2.new(1, -56, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = C.txt1,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 24,
            }, card)

            local track = Make("Frame", {
                Size             = UDim2.new(0, 40, 0, 22),
                Position         = UDim2.new(1, -40, 0.5, -11),
                BackgroundColor3 = state and theme.main or C.bg4,
                BorderSizePixel  = 0,
                ZIndex           = 24,
            }, card)
            AddCorner(11, track)
            local trackStroke = AddStroke(1, state and theme.main or C.bdr, track)

            local thumb = Make("Frame", {
                Size             = UDim2.new(0, 16, 0, 16),
                Position         = state and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
                BackgroundColor3 = state and C.white or C.txt3,
                BorderSizePixel  = 0,
                ZIndex           = 25,
            }, track)
            AddCorner(8, thumb)

            local function Set(val)
                state = val
                Tween(track,       { BackgroundColor3 = val and theme.main or C.bg4 }, 0.2)
                Tween(trackStroke, { Color = val and theme.main or C.bdr }, 0.2)
                Tween(thumb, {
                    Position         = val and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
                    BackgroundColor3 = val and C.white or C.txt3,
                }, 0.2, Enum.EasingStyle.Back)
                if callback then callback(val) end
            end

            -- full-card click hit area
            Make("TextButton", {
                Text             = "",
                Size             = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                ZIndex           = 26,
            }, card).MouseButton1Click:Connect(function() Set(not state) end)

            CardHover(card)
            return { Set = Set, Get = function() return state end }
        end

        -- ── SLIDER ───────────────────────────────────────────────────────────
        function t:Slider(label, minVal, maxVal, default, callback)
            local card = Card(58)
            local val  = math.clamp(default or minVal, minVal, maxVal)
            AddPadding(8, 8, 14, 14, card)

            -- top row: label + value badge
            local topRow = Make("Frame", {
                Size             = UDim2.new(1, 0, 0, 20),
                BackgroundTransparency = 1,
                ZIndex           = 24,
            }, card)

            Make("TextLabel", {
                Text                   = label,
                Size                   = UDim2.new(0.65, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = C.txt1,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 25,
            }, topRow)

            local valFrame = Make("Frame", {
                Size             = UDim2.new(0, 52, 0, 20),
                Position         = UDim2.new(1, -52, 0.5, -10),
                BackgroundColor3 = Tint(theme.main, C.bg4, 0.84),
                BorderSizePixel  = 0,
                ZIndex           = 25,
            }, topRow)
            AddCorner(5, valFrame)
            AddStroke(1, Tint(theme.main, C.bdr, 0.3), valFrame)

            local valLabel = Make("TextLabel", {
                Text                   = tostring(val),
                Size                   = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = theme.light,
                Font                   = Enum.Font.Code,
                TextSize               = 11,
                ZIndex                 = 26,
            }, valFrame)

            -- track
            local track = Make("Frame", {
                Size             = UDim2.new(1, 0, 0, 6),
                Position         = UDim2.new(0, 0, 1, -6),
                BackgroundColor3 = C.bg4,
                BorderSizePixel  = 0,
                ZIndex           = 24,
            }, card)
            AddCorner(3, track)
            AddStroke(1, C.bdr, track)

            local pct  = (val - minVal) / (maxVal - minVal)
            local fill = Make("Frame", {
                Size             = UDim2.new(pct, 0, 1, 0),
                BackgroundColor3 = theme.main,
                BorderSizePixel  = 0,
                ZIndex           = 25,
            }, track)
            AddCorner(3, fill)
            Make("UIGradient", {
                Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, theme.dark),
                    ColorSequenceKeypoint.new(1, theme.light),
                }),
            }, fill)

            local thumb = Make("Frame", {
                Size             = UDim2.new(0, 16, 0, 16),
                Position         = UDim2.new(pct, -8, 0.5, -8),
                BackgroundColor3 = C.white,
                BorderSizePixel  = 0,
                ZIndex           = 26,
            }, track)
            AddCorner(8, thumb)
            AddStroke(2, theme.main, thumb)

            local sliding = false

            local function UpdateSlider(mouseX)
                local ap   = track.AbsolutePosition.X
                local aw   = track.AbsoluteSize.X
                local p    = math.clamp((mouseX - ap) / aw, 0, 1)
                local newV = math.floor(minVal + p * (maxVal - minVal) + 0.5)
                val             = newV
                valLabel.Text   = tostring(newV)
                fill.Size       = UDim2.new(p, 0, 1, 0)
                thumb.Position  = UDim2.new(p, -8, 0.5, -8)
                if callback then callback(newV) end
            end

            track.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = true
                    UpdateSlider(input.Position.X)
                end
            end)
            UserInputService.InputChanged:Connect(function(input)
                if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
                    UpdateSlider(input.Position.X)
                end
            end)
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    sliding = false
                end
            end)

            CardHover(card)

            return {
                Set = function(v)
                    v = math.clamp(v, minVal, maxVal)
                    val           = v
                    local p       = (v - minVal) / (maxVal - minVal)
                    fill.Size     = UDim2.new(p, 0, 1, 0)
                    thumb.Position = UDim2.new(p, -8, 0.5, -8)
                    valLabel.Text = tostring(v)
                    if callback then callback(v) end
                end,
                Get = function() return val end,
            }
        end

        -- ── DROPDOWN ─────────────────────────────────────────────────────────
        -- The list is parented to Overlay so it ALWAYS renders on top.
        -- It is positioned ABOVE the button using AbsolutePosition.
        function t:Dropdown(label, options, default, callback)
            local card   = Card(42)
            local sel    = default or options[1]
            local isOpen = false
            AddPadding(0, 0, 14, 14, card)

            Make("TextLabel", {
                Text                   = label,
                Size                   = UDim2.new(0.46, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = C.txt1,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 24,
            }, card)

            local dropBtn = Make("TextButton", {
                Text             = sel .. "  ▾",
                Size             = UDim2.new(0.5, 0, 0, 28),
                Position         = UDim2.new(0.5, 0, 0.5, -14),
                BackgroundColor3 = C.bg4,
                TextColor3       = C.txt1,
                Font             = Enum.Font.GothamSemibold,
                TextSize         = 12,
                BorderSizePixel  = 0,
                AutoButtonColor  = false,
                ZIndex           = 24,
            }, card)
            AddCorner(7, dropBtn)
            local dropStroke = AddStroke(1, C.bdr, dropBtn)

            -- List frame sits on Overlay (ZIndex 8000+), always on top
            local optionH  = 28
            local listPad  = 6
            local listH    = #options * optionH + listPad * 2 + (#options - 1) * 3

            local listFrame = Make("Frame", {
                Size             = UDim2.new(0, 0, 0, listH), -- width set on open
                BackgroundColor3 = C.bg3,
                BorderSizePixel  = 0,
                Visible          = false,
                ZIndex           = 8002,
            }, Overlay)
            AddCorner(8, listFrame)
            AddStroke(1, theme.main, listFrame)

            Make("UIListLayout", {
                FillDirection       = Enum.FillDirection.Vertical,
                Padding             = UDim.new(0, 3),
                SortOrder           = Enum.SortOrder.LayoutOrder,
            }, listFrame)
            AddPadding(listPad, listPad, listPad, listPad, listFrame)

            -- Option buttons
            local optBtns = {}
            for i, opt in ipairs(options) do
                local isActive = (opt == sel)
                local ob = Make("TextButton", {
                    Text             = opt,
                    Size             = UDim2.new(1, 0, 0, optionH),
                    BackgroundColor3 = isActive and Tint(theme.main, C.bg4, 0.80) or C.bg4,
                    TextColor3       = isActive and theme.light or C.txt2,
                    Font             = Enum.Font.GothamSemibold,
                    TextSize         = 12,
                    BorderSizePixel  = 0,
                    AutoButtonColor  = false,
                    LayoutOrder      = i,
                    ZIndex           = 8003,
                }, listFrame)
                AddCorner(5, ob)

                ob.MouseEnter:Connect(function()
                    if opt ~= sel then Tween(ob, { BackgroundColor3 = Tint(theme.main, C.bg4, 0.9) }, 0.08) end
                end)
                ob.MouseLeave:Connect(function()
                    if opt ~= sel then Tween(ob, { BackgroundColor3 = C.bg4 }, 0.08) end
                end)

                ob.MouseButton1Click:Connect(function()
                    sel           = opt
                    dropBtn.Text  = opt .. "  ▾"
                    listFrame.Visible = false
                    isOpen        = false
                    Tween(dropBtn,   { BackgroundColor3 = C.bg4 }, 0.1)
                    Tween(dropStroke, { Color = C.bdr }, 0.1)
                    -- update highlights
                    for _, info in ipairs(optBtns) do
                        local active = (info.opt == opt)
                        Tween(info.btn, {
                            BackgroundColor3 = active and Tint(theme.main, C.bg4, 0.80) or C.bg4,
                            TextColor3       = active and theme.light or C.txt2,
                        }, 0.12)
                    end
                    if callback then callback(opt) end
                end)

                table.insert(optBtns, { btn = ob, opt = opt })
            end

            -- Open: place list ABOVE the button using AbsolutePosition
            local function OpenDropdown()
                local ap = dropBtn.AbsolutePosition
                local as = dropBtn.AbsoluteSize
                listFrame.Size     = UDim2.new(0, as.X, 0, listH)
                -- position above the button
                listFrame.Position = UDim2.new(0, ap.X, 0, ap.Y - listH - 4)
                listFrame.Visible  = true
                isOpen             = true
                Tween(dropBtn,    { BackgroundColor3 = Tint(theme.main, C.bg4, 0.80) }, 0.12)
                Tween(dropStroke, { Color = theme.main }, 0.12)
            end

            local function CloseDropdown()
                listFrame.Visible = false
                isOpen            = false
                Tween(dropBtn,    { BackgroundColor3 = C.bg4 }, 0.12)
                Tween(dropStroke, { Color = C.bdr }, 0.12)
            end

            dropBtn.MouseButton1Click:Connect(function()
                if isOpen then CloseDropdown() else OpenDropdown() end
            end)

            -- Close when clicking anywhere else
            UserInputService.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
                    task.wait() -- let option click fire first
                    if listFrame.Visible then CloseDropdown() end
                end
            end)

            CardHover(card)

            return {
                Set = function(v)
                    sel           = v
                    dropBtn.Text  = v .. "  ▾"
                    for _, info in ipairs(optBtns) do
                        local active = (info.opt == v)
                        info.btn.BackgroundColor3 = active and Tint(theme.main, C.bg4, 0.80) or C.bg4
                        info.btn.TextColor3       = active and theme.light or C.txt2
                    end
                    if callback then callback(v) end
                end,
                Get = function() return sel end,
            }
        end

        -- ── KEYBIND ──────────────────────────────────────────────────────────
        function t:Keybind(label, default, callback)
            local card      = Card(42)
            local current   = default or "None"
            local listening = false
            AddPadding(0, 0, 14, 14, card)

            Make("TextLabel", {
                Text                   = label,
                Size                   = UDim2.new(0.58, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3             = C.txt1,
                Font                   = Enum.Font.GothamSemibold,
                TextSize               = 13,
                TextXAlignment         = Enum.TextXAlignment.Left,
                ZIndex                 = 24,
            }, card)

            local kBtn = Make("TextButton", {
                Text             = "[ " .. current .. " ]",
                Size             = UDim2.new(0, 96, 0, 28),
                Position         = UDim2.new(1, -96, 0.5, -14),
                BackgroundColor3 = C.bg4,
                TextColor3       = C.txt1,
                Font             = Enum.Font.Code,
                TextSize         = 12,
                BorderSizePixel  = 0,
                AutoButtonColor  = false,
                ZIndex           = 24,
            }, card)
            AddCorner(7, kBtn)
            local kStroke = AddStroke(1, C.bdr, kBtn)

            kBtn.MouseButton1Click:Connect(function()
                if listening then return end
                listening    = true
                kBtn.Text    = "  .  .  ."
                Tween(kBtn,    { BackgroundColor3 = Tint(theme.main, C.bg4, 0.80) }, 0.12)
                Tween(kStroke, { Color = theme.main }, 0.12)

                local conn
                conn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if gameProcessed then return end
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        current   = input.KeyCode.Name
                        kBtn.Text = "[ " .. current .. " ]"
                        Tween(kBtn,    { BackgroundColor3 = C.bg4 }, 0.12)
                        Tween(kStroke, { Color = C.bdr }, 0.12)
                        listening = false
                        conn:Disconnect()
                        if callback then callback(current) end
                    end
                end)
            end)

            CardHover(card)
            return {
                Set = function(k) current = k; kBtn.Text = "[ " .. k .. " ]" end,
                Get = function() return current end,
            }
        end

        -- ── TEXTINPUT ────────────────────────────────────────────────────────
        function t:TextInput(label, placeholder, callback)
            local card = Card(42)
