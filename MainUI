            Text                   = cfg.Badge,
            Size                   = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            TextColor3             = C.txt3,
            Font                   = Enum.Font.Code,
            TextSize               = 10,
            ZIndex                 = 33,
